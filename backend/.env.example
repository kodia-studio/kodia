# Application
APP_NAME=kodia
APP_ENV=development
APP_PORT=8080
APP_DEBUG=true
APP_BASE_URL=http://localhost:8080
APP_FRONTEND_URL=http://localhost:3000

# Database
APP_DATABASE_DRIVER=postgres
APP_DATABASE_HOST=localhost
APP_DATABASE_PORT=5432
APP_DATABASE_NAME=kodia_db
APP_DATABASE_USER=kodia
APP_DATABASE_PASSWORD=password
APP_DATABASE_SSL_MODE=disable
APP_DATABASE_TIMEZONE=UTC

# Redis
APP_REDIS_HOST=localhost
APP_REDIS_PORT=6379
APP_REDIS_PASSWORD=
APP_REDIS_DB=0

# JWT
APP_JWT_ACCESS_SECRET=supersecretaccesskey
APP_JWT_REFRESH_SECRET=supersecretrefreshkey
APP_JWT_ACCESS_EXPIRY_HOURS=1
APP_JWT_REFRESH_EXPIRY_DAYS=30

# CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
