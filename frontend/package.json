{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"codegen": "mkdir -p src/lib/types/generated && npx swagger2openapi ../../kodia/backend/docs/swagger.yaml -o src/lib/types/generated/openapi.yaml --patch && npx openapi-typescript src/lib/types/generated/openapi.yaml -o src/lib/types/generated/api.d.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.2.11",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.8",
		"@types/node": "^24",
		"@vite-pwa/sveltekit": "^1.1.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"openapi-typescript": "^7.13.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"swagger2openapi": "^7.0.8",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vite-plugin-pwa": "^1.2.0"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.1",
		"@tanstack/svelte-table": "^8.21.3",
		"@tanstack/table-core": "^8.20.5",
		"@tiptap/core": "^3.22.4",
		"@tiptap/starter-kit": "^3.22.4",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"d3": "^7.9.0",
		"layerchart": "^1.0.13",
		"lucide-svelte": "^1.0.1",
		"mode-watcher": "^1.1.0",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"overrides": {
		"svelte": "^5.55.2",
		"cookie": "^0.7.0"
	}
}
