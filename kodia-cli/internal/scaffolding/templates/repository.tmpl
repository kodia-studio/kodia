package postgres

import (
	"context"
	"errors"

	"github.com/kodia/framework/backend/internal/core/domain"
	"github.com/kodia/framework/backend/internal/core/ports"
	"github.com/kodia/framework/backend/pkg/pagination"
	"gorm.io/gorm"
)

type {{.LowerName}}Repository struct {
	db *gorm.DB
}

func New{{.Name}}Repository(db *gorm.DB) ports.{{.Name}}Repository {
	return &{{.LowerName}}Repository{db: db}
}

func (r *{{.LowerName}}Repository) FindAll(ctx context.Context, params pagination.Params) ([]domain.{{.Name}}, int64, error) {
	var items []domain.{{.Name}}
	var total int64

	query := r.db.WithContext(ctx).Model(&domain.{{.Name}}{})

	if err := query.Count(&total).Error; err != nil {
		return nil, 0, err
	}

	if err := query.Scopes(pagination.Paginate(&params)).Find(&items).Error; err != nil {
		return nil, 0, err
	}

	return items, total, nil
}

func (r *{{.LowerName}}Repository) FindByID(ctx context.Context, id string) (*domain.{{.Name}}, error) {
	var item domain.{{.Name}}
	err := r.db.WithContext(ctx).Where("id = ?", id).First(&item).Error
	if err != nil {
		if errors.Is(err, gorm.ErrRecordNotFound) {
			return nil, domain.ErrNotFound
		}
		return nil, err
	}
	return &item, nil
}

func (r *{{.LowerName}}Repository) Create(ctx context.Context, item *domain.{{.Name}}) error {
	return r.db.WithContext(ctx).Create(item).Error
}

func (r *{{.LowerName}}Repository) Update(ctx context.Context, item *domain.{{.Name}}) error {
	return r.db.WithContext(ctx).Save(item).Error
}

func (r *{{.LowerName}}Repository) Delete(ctx context.Context, id string) error {
	return r.db.WithContext(ctx).Where("id = ?", id).Delete(&domain.{{.Name}}{}).Error
}
